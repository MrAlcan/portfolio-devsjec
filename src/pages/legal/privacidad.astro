---
import MainLayout from '../../presentation/web/layouts/MainLayout.astro'
import NavBar from '../../presentation/web/components/shared/NavBar.astro'
import Footer from '../../presentation/web/components/shared/Footer.astro'
import { PUBLIC_ENVIRONMENTS } from '../../infrastructure/config/public-enviroments'
import { buildBreadcrumbSchema } from '../../presentation/web/seo/structuredData'

export const prerender = true

const siteUrl = (Astro.site ?? new URL('https://devsjec.com')).href
const breadcrumb = buildBreadcrumbSchema(siteUrl, [
  { name: 'Inicio', url: '/' },
  { name: 'Privacidad', url: '/legal/privacidad' }
])
---

<MainLayout
  title="Política de Privacidad — DEVSJEC SRL"
  description="Política de privacidad de DEVSJEC SRL: cómo tratamos los datos personales que recibimos a través del sitio."
  extraSchemas={[breadcrumb]}
>
  <div class="bg-background text-on-background font-body min-h-screen flex flex-col">
    <NavBar />
    <main id="main" tabindex="-1" class="flex-1 max-w-3xl mx-auto px-8 py-32">
      <p class="text-xs font-mono uppercase text-outline tracking-[0.2em] mb-4">Legal</p>
      <h1 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-8">Política de Privacidad</h1>
      <p class="text-on-surface-variant mb-8">Última actualización: { new Date().toISOString().slice(0, 10) }</p>

      <div class="prose prose-invert max-w-none space-y-6 text-on-surface-variant">
        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">1. Responsable del tratamiento</h2>
          <p>{ PUBLIC_ENVIRONMENTS.COMPANY_NAME } SRL, con domicilio en { PUBLIC_ENVIRONMENTS.COMPANY_LOCATION }, es la responsable del tratamiento de los datos personales que se recolectan a través de este sitio web. Para cualquier consulta sobre privacidad, escribir a <a class="text-primary hover:underline" href={`mailto:${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`}>{ PUBLIC_ENVIRONMENTS.COMPANY_EMAIL }</a>.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">2. Datos que recolectamos</h2>
          <p>Solo recolectamos los datos que el usuario nos proporciona voluntariamente a través del formulario de contacto: nombre completo, empresa (opcional), correo electrónico y mensaje.</p>
          <p>Adicionalmente, usamos un sistema de analítica web (Umami) que registra eventos agregados de navegación (páginas visitadas, país, navegador, referrer) <strong>sin usar cookies</strong> y sin identificar individualmente a las personas.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">3. Finalidad del tratamiento</h2>
          <ul class="list-disc pl-6 space-y-2">
            <li>Responder consultas comerciales y técnicas enviadas por formulario.</li>
            <li>Enviar propuestas o información solicitada por el usuario.</li>
            <li>Medir de forma agregada el uso del sitio para mejorarlo.</li>
          </ul>
          <p class="mt-4">No usamos los datos para marketing automático, perfilamiento publicitario, ni los compartimos con terceros para esos fines.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">4. Conservación</h2>
          <p>Los mensajes del formulario se conservan durante el tiempo necesario para responder a la consulta y mantener un historial razonable de la relación comercial. El usuario puede solicitar su eliminación en cualquier momento escribiendo al correo de contacto.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">5. Derechos del usuario</h2>
          <p>El usuario tiene derecho a acceder, rectificar, suprimir y portar sus datos personales, así como a oponerse a su tratamiento. Para ejercer estos derechos, basta con enviar un correo a <a class="text-primary hover:underline" href={`mailto:${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`}>{ PUBLIC_ENVIRONMENTS.COMPANY_EMAIL }</a>.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">6. Seguridad</h2>
          <p>Aplicamos medidas técnicas y organizativas razonables para proteger los datos contra acceso no autorizado, pérdida o alteración, incluyendo cifrado en tránsito (HTTPS) y acceso restringido al servidor de correo.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-on-surface mt-8 mb-4">7. Cambios</h2>
          <p>Esta política puede actualizarse. La versión vigente siempre está publicada en esta URL con su fecha de última actualización.</p>
        </section>
      </div>
    </main>
    <Footer />
  </div>
</MainLayout>
