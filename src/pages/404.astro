---
import MainLayout from '../presentation/web/layouts/MainLayout.astro'
import NavBar from '../presentation/web/components/shared/NavBar.astro'
import Footer from '../presentation/web/components/shared/Footer.astro'

export const prerender = true
---

<MainLayout
  title="Página no encontrada (404) — DEVSJEC SRL"
  description="La página que buscas no existe o fue movida. Vuelve al inicio o explora nuestros servicios."
  noindex={true}
>
  <div class="bg-background text-on-background font-body min-h-screen flex flex-col">
    <NavBar />
    <main id="main" tabindex="-1" class="flex-1 flex items-center justify-center px-8 py-32">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-mono uppercase text-outline tracking-[0.2em] mb-6">Error 404</p>
        <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter bg-linear-to-br from-primary via-secondary to-on-background bg-clip-text text-transparent mb-6 leading-tight">
          Esta página se perdió en el código
        </h1>
        <p class="text-lg text-on-surface-variant mb-12 max-w-xl mx-auto">
          La URL que intentas visitar no existe o fue movida. Probablemente un puntero nulo, o un deploy reciente. Te ayudamos a volver a un lugar conocido.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/"
            class="w-full sm:w-auto primary-gradient text-on-primary px-8 py-4 rounded-xl font-bold inline-flex items-center justify-center gap-2 shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/35 hover:-translate-y-0.5 transition-all duration-200 active:scale-95">
            Volver al inicio
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
          </a>
          <a
            href="/#contacto"
            class="w-full sm:w-auto border border-outline-variant/40 bg-surface-container/20 backdrop-blur px-8 py-4 rounded-xl font-bold text-on-surface hover:bg-surface-container-high transition-colors">
            Contáctanos
          </a>
        </div>
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="/#servicios">Servicios</a>
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="/#proyectos">Proyectos</a>
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="/#equipo">Equipo</a>
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="/blog">Blog</a>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</MainLayout>
