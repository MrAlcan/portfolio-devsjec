---
import ProcessStepCard from '../../shared/cards/ProcessStepCard.astro'

interface Step {
    number: number
    title: string
    description: string
}

const steps: Step[] = [
    {
        number: 1,
        title: 'Discovery',
        description: 'Entendemos tus objetivos de negocio y limitaciones técnicas.'
    },
    {
        number: 2,
        title: 'Architecture',
        description: 'Diseño detallado de la infraestructura y lógica del sistema.'
    },
    {
        number: 3,
        title: 'Development',
        description: 'Codificación ágil con revisiones continuas y QA riguroso.'
    },
    {
        number: 4,
        title: 'Delivery',
        description: 'Despliegue optimizado, monitoreo y soporte post-lanzamiento.'
    }
]

//TODO: Linea conectora entre cards
---
<!-- Process Section -->
<section class="py-32 px-8 max-w-7xl mx-auto">
    <div class="text-center mb-20">
        <h2 class="text-4xl font-headline font-extrabold tracking-tight mb-4">Nuestro Proceso</h2>
        <p class="text-on-surface-variant">De la idea a la producción con precisión quirúrgica.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <div class="hidden md:block absolute top-12 left-0 w-full h-px bg-outline-variant/30 -z-10"></div>
        {
            steps.map((step) => (
                <ProcessStepCard {...step} />
            ))
        }
    </div>
</section>