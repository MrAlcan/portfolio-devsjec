---
import ProcessStepCard from '../../shared/cards/ProcessStepCard.astro'

interface Step {
    number: number
    title: string
    description: string
}

const steps: Step[] = [
    {
        number: 1,
        title: 'Descubrimiento',
        description: 'Entendemos tus objetivos de negocio y limitaciones técnicas.'
    },
    {
        number: 2,
        title: 'Arquitectura',
        description: 'Diseño detallado de la infraestructura y lógica del sistema.'
    },
    {
        number: 3,
        title: 'Desarrollo',
        description: 'Codificación ágil con revisiones continuas y QA riguroso.'
    },
    {
        number: 4,
        title: 'Entrega',
        description: 'Despliegue optimizado, monitoreo y soporte post-lanzamiento.'
    }
]

---
<!-- Process Section -->
<section class="py-32 px-8 max-w-7xl mx-auto" id="proceso">
    <div class="text-center mb-20">
        <p class="text-xs font-mono text-primary uppercase tracking-[0.2em] mb-3">Cómo trabajamos</p>
        <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-4">Nuestro Proceso</h2>
        <div class="h-0.5 w-24 primary-gradient mx-auto mb-6"></div>
        <p class="text-on-surface-variant text-lg">De la idea a la producción con precisión quirúrgica.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <div class="hidden md:block absolute top-12 left-[12%] w-[76%] h-0.5 bg-linear-to-r from-transparent via-primary/40 to-transparent -z-10" aria-hidden="true"></div>
        {
            steps.map((step) => (
                <ProcessStepCard {...step} />
            ))
        }
    </div>
</section>