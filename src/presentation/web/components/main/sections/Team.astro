---
import { PUBLIC_ENVIRONMENTS } from '../../../../../infrastructure/config/public-enviroments'
import TeamMemberCard from '../../shared/cards/TeamMemberCard.astro'

interface Member {
    name: string
    role: string
    description: string
    image: string
    imageAlt: string
}

const members: Member[] = [
    {
        name: PUBLIC_ENVIRONMENTS.MEMBER1_NAME,
        role: PUBLIC_ENVIRONMENTS.MEMBER1_ROLE_ES,
        description: PUBLIC_ENVIRONMENTS.MEMBER1_BIO_ES,
        image: PUBLIC_ENVIRONMENTS.MEMBER1_PHOTO,
        imageAlt: `Foto de ${ PUBLIC_ENVIRONMENTS.MEMBER1_NAME }, ${ PUBLIC_ENVIRONMENTS.MEMBER1_ROLE_ES } en DEVSJEC SRL`
    },
    {
        name: PUBLIC_ENVIRONMENTS.MEMBER2_NAME,
        role: PUBLIC_ENVIRONMENTS.MEMBER2_ROLE_ES,
        description: PUBLIC_ENVIRONMENTS.MEMBER2_BIO_ES,
        image: PUBLIC_ENVIRONMENTS.MEMBER2_PHOTO,
        imageAlt: `Foto de ${ PUBLIC_ENVIRONMENTS.MEMBER2_NAME }, ${ PUBLIC_ENVIRONMENTS.MEMBER2_ROLE_ES } en DEVSJEC SRL`
    },
    {
        name: PUBLIC_ENVIRONMENTS.MEMBER3_NAME,
        role: PUBLIC_ENVIRONMENTS.MEMBER3_ROLE_ES,
        description: PUBLIC_ENVIRONMENTS.MEMBER3_BIO_ES,
        image: PUBLIC_ENVIRONMENTS.MEMBER3_PHOTO,
        imageAlt: `Foto de ${ PUBLIC_ENVIRONMENTS.MEMBER3_NAME }, ${ PUBLIC_ENVIRONMENTS.MEMBER3_ROLE_ES } en DEVSJEC SRL`
    }
]

---

<section class="bg-surface-container-low py-32" id="equipo">
    <div class="max-w-7xl mx-auto px-8">
        <div class="text-center mb-20">
            <p class="text-xs font-mono text-primary uppercase tracking-[0.2em] mb-3">Quiénes somos</p>
            <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-4">El Equipo</h2>
            <div class="h-0.5 w-24 primary-gradient mx-auto mb-6"></div>
            <p class="text-on-surface-variant text-lg">Los arquitectos detrás de cada línea de código.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            { members.map( member => (
                <TeamMemberCard
                    imageUrl={ member.image }
                    imageAlt={ member.imageAlt }
                    name={ member.name }
                    role={ member.role }
                    description={ member.description }
                />
            ) ) }
        </div>
    </div>
</section>