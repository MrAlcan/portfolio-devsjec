---
import { PUBLIC_ENVIRONMENTS } from '../../../../../infrastructure/config/public-enviroments'
import WhyUsItemList from '../../shared/itemList/WhyUsItemList.astro'

const startCorch = "{"
const endCorch = "}"

interface ItemList {
    icon: string
    dataIcon: string
    title: string
    description: string
}

const items: ItemList[] = [
    {
        icon: "verified",
        dataIcon: "verified",
        title: "Arquitectura y Código Limpio",
        description: "Priorizamos la mantenibilidad y escalabilidad del código. Software que no envejece, evoluciona."
    },
    {
        icon: "shutter_speed",
        dataIcon: "shutter_speed",
        title: "Entrega Comprometida",
        description: "Metodologías ágiles que garantizan visibilidad total y cumplimiento estricto de plazos."
    },
    {
        icon: "psychology",
        dataIcon: "psychology",
        title: "Expertos Técnicos",
        description: "Ingenieros Senior con experiencia en proyectos de impacto nacional y regional."
    }
]

---
<!-- Why Us & Code Block Section -->
    <section class="bg-surface-container-low py-32 overflow-hidden" id="nosotros">
        <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <p class="text-xs font-mono text-primary uppercase tracking-[0.2em] mb-3">Nuestra diferencia</p>
                <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-4">¿Por qué { PUBLIC_ENVIRONMENTS.COMPANY_NAME }?</h2>
                <div class="h-0.5 w-24 primary-gradient mb-8"></div>
                <div class="space-y-12">
                    {
                        items.map((item) => (
                            <WhyUsItemList icon={item.icon} dataIcon={item.dataIcon} title={item.title} description={item.description} />
                        ))
                    }
                </div>
            </div>
            <div class="relative group">
                <div
                    class="absolute -inset-4 bg-primary/20 blur-2xl rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                </div>
                <div
                    class="relative bg-zinc-950 border border-zinc-800 rounded-xl overflow-hidden shadow-2xl">
                    <div
                        class="flex items-center gap-2 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-400"></div>
                            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
                            <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
                        </div>
                        <div class="text-[10px] font-mono text-zinc-500 ml-4 tracking-widest uppercase">
                            architecture.go</div>
                    </div>
                    <div class="p-6 font-mono text-sm overflow-x-auto">
                        <pre class="text-zinc-100"><span class="text-violet-400">package</span> main
    <span class="text-indigo-400">func</span> <span class="text-violet-400">BuildFuture</span>(project Project) { startCorch }
        <span class="text-zinc-500">// Ensuring high performance architecture</span>
        system := Architecture.NewSystem()

        <span class="text-indigo-400">for</span> _, requirement := <span class="text-indigo-400">range</span> project.Needs { startCorch }
            system.ImplementScalableSolution(requirement)
        { endCorch }

        <span class="text-violet-400">return</span> system.DeployToProduction()
    { endCorch }


                        </pre>
                    </div>
                </div>
            </div>
        </div>
    </section>