---
import { PUBLIC_ENVIRONMENTS } from '../../../../../infrastructure/config/public-enviroments'
import WhyUsItemList from '../../shared/itemList/WhyUsItemList.astro'

const startCorch = "{"
const endCorch = "}"

interface ItemList {
    icon: string
    dataIcon: string
    title: string
    description: string
}

const items: ItemList[] = [
    {
        icon: "verified",
        dataIcon: "verified",
        title: "Arquitectura y Código Limpio",
        description: "Priorizamos la mantenibilidad y escalabilidad del código. Software que no envejece, evoluciona."
    },
    {
        icon: "shutter_speed",
        dataIcon: "shutter_speed",
        title: "Entrega Comprometida",
        description: "Metodologías ágiles que garantizan visibilidad total y cumplimiento estricto de plazos."
    },
    {
        icon: "psychology",
        dataIcon: "psychology",
        title: "Expertos Técnicos",
        description: "Ingenieros Senior con experiencia en proyectos de impacto nacional y regional."
    }
]

---
<!-- Why Us & Code Block Section -->
    <section class="bg-surface-container-low py-32 overflow-hidden" id="nosotros">
        <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl font-headline font-extrabold tracking-tight mb-8">¿Por qué { PUBLIC_ENVIRONMENTS.COMPANY_NAME }?</h2>
                <div class="space-y-12">
                    {
                        items.map((item) => (
                            <WhyUsItemList icon={item.icon} dataIcon={item.dataIcon} title={item.title} description={item.description} />
                        ))
                    }
                </div>
            </div>
            <div class="relative group">
                <div
                    class="absolute -inset-4 bg-primary/20 blur-2xl rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                </div>
                <div
                    class="relative bg-[#050508] border border-outline-variant/30 rounded-xl overflow-hidden shadow-2xl">
                    <div
                        class="flex items-center gap-2 px-4 py-3 bg-surface-container-high border-b border-outline-variant/30">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                            <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                            <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                        </div>
                        <div class="text-[10px] font-mono text-outline-variant ml-4 tracking-widest uppercase">
                            architecture.go</div>
                    </div>
                    <div class="p-6 font-mono text-sm overflow-x-auto">
                        <pre class="text-[#f9f5fd]"><span class="text-secondary">package</span> main
    <span class="text-primary">func</span> <span class="text-secondary">BuildFuture</span>(project Project) { startCorch }
        <span class="text-on-surface-variant">// Ensuring high performance architecture</span>
        system := Architecture.NewSystem()
                                
        <span class="text-primary">for</span> _, requirement := <span class="text-primary">range</span> project.Needs { startCorch }
            system.ImplementScalableSolution(requirement)
        { endCorch }
                                
        <span class="text-secondary">return</span> system.DeployToProduction()
    { endCorch }


                        </pre>
                    </div>
                </div>
            </div>
        </div>
    </section>