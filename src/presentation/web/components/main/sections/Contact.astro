---
import { PUBLIC_ENVIRONMENTS } from '../../../../../infrastructure/config/public-enviroments'
import ContactForm from "../../shared/ContactForm.astro"

const whatsappUrl = `https://wa.me/${PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP.replace(/[^0-9]/g, '')}`
---

<!-- Contact Section -->
<section class="py-32 bg-surface-container-low" id="contacto">
    <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
            <p class="text-xs font-mono text-primary uppercase tracking-[0.2em] mb-3">Contacto</p>
            <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-4">Hablemos de tu próximo paso</h2>
            <div class="h-0.5 w-24 primary-gradient mb-8"></div>
            <p class="text-on-surface-variant text-lg mb-12">Estamos listos para materializar tu visión técnica.
                Contáctanos para una consultoría inicial sin compromiso.</p>
            <div class="space-y-6">
                <div class="flex items-center gap-4 p-3 -m-3 rounded-xl">
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                        <span class="material-symbols-outlined" aria-hidden="true">location_on</span>
                    </div>
                    <div>
                        <p class="text-xs font-mono uppercase text-outline">Ubicación</p>
                        <p class="font-bold text-on-surface">{ PUBLIC_ENVIRONMENTS.COMPANY_LOCATION }</p>
                    </div>
                </div>
                <a href={`mailto:${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`}
                    class="group flex items-center gap-4 p-3 -m-3 rounded-xl hover:bg-surface-container transition-colors duration-200"
                    aria-label={`Enviar email a ${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`}>
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 group-hover:scale-110 transition-transform duration-200">
                        <span class="material-symbols-outlined" aria-hidden="true">mail</span>
                    </div>
                    <div>
                        <p class="text-xs font-mono uppercase text-outline">Email</p>
                        <p class="font-bold text-on-surface group-hover:text-primary transition-colors duration-200">{ PUBLIC_ENVIRONMENTS.COMPANY_EMAIL }</p>
                    </div>
                </a>
                <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
                    class="group flex items-center gap-4 p-3 -m-3 rounded-xl hover:bg-surface-container transition-colors duration-200"
                    aria-label={`Contactar por WhatsApp al ${PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP}`}>
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 group-hover:scale-110 transition-transform duration-200">
                        <span class="material-symbols-outlined" aria-hidden="true">chat</span>
                    </div>
                    <div>
                        <p class="text-xs font-mono uppercase text-outline">WhatsApp</p>
                        <p class="font-bold text-primary">{ PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP }</p>
                    </div>
                </a>
            </div>
        </div>
        <ContactForm/>
    </div>
</section>
