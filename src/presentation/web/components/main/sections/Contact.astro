<!-- Contact Section -->
    <section class="py-32 bg-surface-container-low" id="contacto">
        <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-16">
            <div>
                <h2 class="text-4xl font-headline font-extrabold tracking-tight mb-8">Hablemos de tu próximo paso</h2>
                <p class="text-on-surface-variant text-lg mb-12">Estamos listos para materializar tu visión técnica.
                    Contáctanos para una consultoría inicial sin compromiso.</p>
                <div class="space-y-8">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">location_on</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono uppercase text-outline">Ubicación</p>
                            <p class="font-bold">La Paz, Bolivia</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">mail</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono uppercase text-outline">Email</p>
                            <p class="font-bold">contacto@devsjec.com</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">chat</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono uppercase text-outline">WhatsApp</p>
                            <p class="font-bold text-primary">+591 700 00000</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-surface-container border border-outline-variant/30 p-8 rounded-xl">
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-mono text-outline uppercase">Nombre Completo</label>
                            <input
                                class="w-full bg-surface-container-low border-0 focus:ring-2 focus:ring-primary rounded-xl p-4 text-on-surface"
                                placeholder="John Doe" type="text" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-mono text-outline uppercase">Empresa</label>
                            <input
                                class="w-full bg-surface-container-low border-0 focus:ring-2 focus:ring-primary rounded-xl p-4 text-on-surface"
                                placeholder="Your Corp" type="text" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-mono text-outline uppercase">Email de contacto</label>
                        <input
                            class="w-full bg-surface-container-low border-0 focus:ring-2 focus:ring-primary rounded-xl p-4 text-on-surface"
                            placeholder="john@example.com" type="email" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-mono text-outline uppercase">Tu Mensaje</label>
                        <textarea
                            class="w-full bg-surface-container-low border-0 focus:ring-2 focus:ring-primary rounded-xl p-4 text-on-surface"
                            placeholder="Cuéntanos sobre tu proyecto..." rows="4"></textarea>
                    </div>
                    <button
                        class="w-full primary-gradient text-on-primary-container font-bold py-4 rounded-xl hover:opacity-90 transition-opacity">
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </section>