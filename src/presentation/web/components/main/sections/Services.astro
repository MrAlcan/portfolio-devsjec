---
import ServiceCard from '../../shared/cards/ServiceCard.astro'
---

<!-- Services Section (Bento Grid Style) -->
    <section class="py-32 px-8 max-w-7xl mx-auto" id="servicios">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
            <div class="max-w-2xl">
                <p class="text-xs font-mono text-primary uppercase tracking-[0.2em] mb-3">Qué hacemos</p>
                <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-4">Nuestros Servicios</h2>
                <div class="h-0.5 w-24 primary-gradient mb-6"></div>
                <p class="text-on-surface-variant text-lg">Soluciones técnicas diseñadas para escalar con la ambición de
                    tu empresa.</p>
            </div>
            <span class="text-xs font-mono text-outline uppercase tracking-[0.2em]">Excelencia en Ingeniería</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <ServiceCard
                dataIcon="custom_typography"
                icon="data_object"
                title="Software a Medida"
                description="Arquitecturas robustas diseñadas desde cero para resolver problemas operativos complejos."
            />
            <ServiceCard
                dataIcon="devices"
                icon="devices"
                title="Web y Móvil"
                description="Experiencias digitales de alta gama con foco en rendimiento, UX y accesibilidad universal."
            />
            <ServiceCard
                dataIcon="smart_toy"
                icon="smart_toy"
                title="IA &amp; Automatización"
                description="Implementación de LLMs y modelos predictivos para optimizar la toma de decisiones."
            />
            <ServiceCard
                dataIcon="troubleshoot"
                icon="troubleshoot"
                title="Consultoría IT"
                description="Asesoría estratégica en transformación digital y modernización de infraestructuras legacy."
            />
            <ServiceCard
                dataIcon="account_balance"
                icon="account_balance"
                title="Sistemas Institucionales"
                description="Desarrollo de ERPs y sistemas de gestión de alto cumplimiento para el sector público y privado."
            />
            <ServiceCard
                dataIcon="cloud_done"
                icon="cloud_done"
                title="DevOps &amp; Cloud"
                description="Despliegue continuo, escalabilidad automática y seguridad nivel bancario en la nube."
            />
        </div>
    </section>

