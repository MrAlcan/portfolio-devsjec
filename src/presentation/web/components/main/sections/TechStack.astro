---
import { PUBLIC_ENVIRONMENTS } from '../../../../../infrastructure/config/public-enviroments'

const techStack: string[] = PUBLIC_ENVIRONMENTS.COMPANY_STACK?.split(',') || []

---

<!-- Tech Stack Marquee -->
<div class="py-12 border-y border-outline-variant/10 bg-surface">
    <div class="max-w-7xl mx-auto px-8 overflow-hidden marquee-container">
        <div
            class="flex items-center gap-16 animate-marquee whitespace-nowrap opacity-50 grayscale hover:grayscale-0 transition-all">
            {techStack.map((tech) => (
                <span class="text-2xl font-mono tracking-widest">{tech}</span>
            ))}
            <!-- Duplicate for seamless loop -->
            {techStack.map((tech) => (
                <span class="text-2xl font-mono tracking-widest">{tech}</span>
            ))}
        </div>
    </div>
</div>
<style>
    .marquee-container {
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
</style>