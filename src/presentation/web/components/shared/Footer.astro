---
import { PUBLIC_ENVIRONMENTS } from '../../../../infrastructure/config/public-enviroments'
import ThemeToggle from './ThemeToggle.astro'
const year = new Date().getFullYear()
---
<!-- Footer -->
    <footer class="w-full py-16 px-8 border-t border-primary/10 bg-surface-container-low">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 max-w-7xl mx-auto">
            <div class="md:col-span-1">
                <div class="text-xl font-black text-on-surface mb-4 font-headline">DEVSJEC</div>
                <p class="font-inter text-sm text-on-surface-variant mb-6 leading-relaxed">
                    Elevando el estándar del desarrollo de software desde el corazón de los Andes.
                </p>
                <div class="flex gap-4" aria-label="Íconos decorativos de tecnología">
                    <span class="material-symbols-outlined text-outline hover:text-on-surface transition-colors duration-200"
                        data-icon="terminal" aria-hidden="true">terminal</span>
                    <span class="material-symbols-outlined text-outline hover:text-on-surface transition-colors duration-200"
                        data-icon="code" aria-hidden="true">code</span>
                    <span class="material-symbols-outlined text-outline hover:text-on-surface transition-colors duration-200"
                        data-icon="cloud" aria-hidden="true">cloud</span>
                </div>
            </div>
            <div class="md:col-span-1">
                <h2 class="text-on-surface font-bold mb-4 text-base">Navegación</h2>
                <ul class="space-y-3 font-inter text-sm">
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/#servicios">Servicios</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/#nosotros">Nosotros</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/#proyectos">Proyectos</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/blog">Blog</a></li>
                </ul>
            </div>
            <div class="md:col-span-1">
                <h2 class="text-on-surface font-bold mb-4 text-base">Contacto</h2>
                <ul class="space-y-3 font-inter text-sm">
                    <li><span class="text-on-surface-variant inline-block" aria-label={`Ubicación: ${PUBLIC_ENVIRONMENTS.COMPANY_LOCATION}`}>{ PUBLIC_ENVIRONMENTS.COMPANY_LOCATION }</span></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href={`mailto:${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`} aria-label={`Enviar email a ${PUBLIC_ENVIRONMENTS.COMPANY_EMAIL}`}>{ PUBLIC_ENVIRONMENTS.COMPANY_EMAIL }</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href={`https://wa.me/${PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP.replace(/[^0-9]/g, '')}`} aria-label={`Contactar por WhatsApp al ${PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP}`} target="_blank" rel="noopener noreferrer">{ PUBLIC_ENVIRONMENTS.COMPANY_WHATSAPP }</a></li>
                </ul>
            </div>
            <div class="md:col-span-1">
                <h2 class="text-on-surface font-bold mb-4 text-base">Legal</h2>
                <ul class="space-y-3 font-inter text-sm">
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/legal/privacidad">Privacidad</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/legal/terminos">Términos</a></li>
                    <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200 inline-block"
                            href="/legal/cookies">Cookies</a></li>
                </ul>
                <div class="flex items-center gap-4 mt-6">
                    <ThemeToggle />
                </div>
            </div>
        </div>
        <div
            class="max-w-7xl mx-auto px-8 mt-16 pt-8 border-t border-outline-variant/40 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="font-inter text-sm text-on-surface-variant">© { year } { PUBLIC_ENVIRONMENTS.COMPANY_NAME } SRL. { PUBLIC_ENVIRONMENTS.COMPANY_LOCATION }.</p>
        </div>
    </footer>
