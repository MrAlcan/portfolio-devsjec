---
interface Props {
  imageUrl: string
  imageAlt: string
  name: string
  role: string
  description: string
}

const { imageUrl, imageAlt, name, role, description }: Props = Astro.props;
---

<div class="bg-surface-container/60 backdrop-blur-xl border border-primary/10 p-8 rounded-full text-center hover:border-primary/40 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/10 transition-all duration-300">
  <div class="relative w-32 h-32 mx-auto mb-6">
    <div class="absolute inset-0 primary-gradient rounded-full p-1">
      <div class="bg-background rounded-full w-full h-full p-1">
        <img
          class="w-full h-full object-cover rounded-full"
          alt={ imageAlt }
          src={ imageUrl }
          width="128"
          height="128"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
  <h4 class="text-xl font-bold mb-1">
    { name }
  </h4>
  <p class="text-primary text-sm font-mono mb-4 uppercase">
    { role }
  </p>
  <p class="text-on-surface-variant text-sm mb-6">
    { description }
  </p>
  <div class="flex justify-center gap-4">
    <button class="material-symbols-outlined text-outline hover:text-primary hover:scale-110 transition-all duration-200 active:scale-95 cursor-pointer" aria-label="Ver perfil profesional" data-icon="hub">
      hub
    </button>
    <button class="material-symbols-outlined text-outline hover:text-primary hover:scale-110 transition-all duration-200 active:scale-95 cursor-pointer" aria-label="Compartir perfil" data-icon="share">
      share
    </button>
  </div>
</div>