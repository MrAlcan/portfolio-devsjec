---
interface Props {
  imgUrl: string
  alt: string
  category: string
  title: string
  description: string
}

const { imgUrl, alt, category, title, description } = Astro.props
---

<article class="group cursor-pointer bg-surface-container/60 backdrop-blur-xl border border-primary/10 rounded-xl overflow-hidden hover:border-primary/40 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/10 transition-all duration-300">
  <div class="relative aspect-video overflow-hidden bg-surface-container">
    <img
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      alt={ alt }
      src={ imgUrl }
      width="800"
      height="450"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-linear-to-t from-surface-container-low/90 via-transparent to-transparent"></div>
    <div class="absolute bottom-4 left-4">
      <span class="text-[10px] font-mono px-2 py-1 rounded bg-primary text-on-primary uppercase tracking-wider">
        { category }
      </span>
    </div>
  </div>
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2 text-on-surface group-hover:text-primary transition-colors duration-200 flex items-center gap-2">
      { title }
      <span class="material-symbols-outlined text-base opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" aria-hidden="true">arrow_forward</span>
    </h3>
    <p class="text-on-surface-variant text-sm leading-relaxed">
      { description }
    </p>
  </div>
</article>
