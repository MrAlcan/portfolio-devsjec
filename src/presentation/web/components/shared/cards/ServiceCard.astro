---

interface Props {
  dataIcon: string
  icon: string
  title: string
  description: string
}

let { dataIcon, icon, title, description }: Props = Astro.props

---

<div class="glass-card p-8 rounded-full flex flex-col gap-6 group hover:border-primary/40 transition-colors">
  <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary/10 text-primary">
    <span class="material-symbols-outlined text-3xl" data-icon={dataIcon}>{icon}</span>
  </div>
  <div>
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-on-surface-variant text-sm leading-relaxed">
      {description}
    </p>
  </div>
</div>