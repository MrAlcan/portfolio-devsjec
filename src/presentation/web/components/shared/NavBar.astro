---
import { PUBLIC_ENVIRONMENTS } from '../../../../infrastructure/config/public-enviroments'
import ThemeToggle from './ThemeToggle.astro'

const navLinks = [
  { href: '/#servicios', section: 'servicios', label: 'Servicios', ariaLabel: 'Ir a la sección de servicios' },
  { href: '/#nosotros', section: 'nosotros', label: 'Nosotros', ariaLabel: 'Ir a la sección nosotros' },
  { href: '/#equipo', section: 'equipo', label: 'Equipo', ariaLabel: 'Ir a la sección del equipo' },
  { href: '/#proyectos', section: 'proyectos', label: 'Proyectos', ariaLabel: 'Ir a la sección de proyectos' },
  { href: '/blog', section: 'blog', label: 'Blog', ariaLabel: 'Ir al blog' },
  { href: '/#contacto', section: 'contacto', label: 'Contacto', ariaLabel: 'Ir a la sección de contacto' }
]

const isBlog = Astro.url.pathname.startsWith('/blog')

const linkClass =
  'relative pb-1 font-headline font-extrabold tracking-tight text-on-surface-variant hover:text-on-surface transition-colors duration-200 ' +
  'after:absolute after:left-0 after:bottom-0 after:h-0.5 after:w-full after:rounded-full after:bg-primary ' +
  'after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 ' +
  'aria-[current=page]:text-primary aria-[current=page]:after:scale-x-100'
---

<header class="fixed top-0 w-full z-50 bg-surface/70 backdrop-blur-xl border-b border-primary/10 shadow-lg shadow-primary/5">
  <nav class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto" role="navigation" aria-label="Navegación principal">
    <a href="/" class="text-2xl font-black text-primary tracking-tighter font-headline transition-opacity hover:opacity-80" aria-label="Inicio — DEVSJEC SRL">{ PUBLIC_ENVIRONMENTS.COMPANY_NAME }</a>
    <div class="hidden md:flex items-center gap-x-8">
      { navLinks.map((link) => (
        <a
          class={linkClass}
          href={link.href}
          data-nav-section={link.section}
          aria-current={isBlog && link.section === 'blog' ? 'page' : undefined}
          aria-label={link.ariaLabel}
        >
          {link.label}
        </a>
      )) }
    </div>
    <div class="flex items-center gap-4">
      <ThemeToggle />
      <a
        href="/#contacto"
        class="bg-primary text-on-primary px-6 py-2.5 rounded-xl font-bold shadow-md shadow-primary/20 hover:shadow-lg hover:shadow-primary/30 hover:-translate-y-0.5 transition-all duration-200 active:scale-95"
        aria-label="Iniciar proyecto con nosotros">
        Trabajemos juntos
      </a>
    </div>
  </nav>
</header>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('a[data-nav-section]')
  const sections = Array.from(links)
    .map((link) => document.getElementById(link.dataset.navSection ?? ''))
    .filter((section): section is HTMLElement => section !== null)

  if (sections.length > 0) {
    const setActive = (id: string) => {
      links.forEach((link) => {
        if (link.dataset.navSection === id) link.setAttribute('aria-current', 'page')
        else link.removeAttribute('aria-current')
      })
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) setActive(entry.target.id)
        }
      },
      { rootMargin: '-35% 0px -60% 0px' }
    )

    sections.forEach((section) => observer.observe(section))
  }
</script>
