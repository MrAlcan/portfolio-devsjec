---
import '../../assets/styles/global.css'
import { PUBLIC_ENVIRONMENTS } from '../../../infrastructure/config/public-enviroments'
import SEO, { type Props as SEOProps } from '../seo/SEO.astro'

type Props = SEOProps

const seoProps = Astro.props as Props

const fontCssHref = 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@700;800&display=swap'
const iconsCssHref = 'https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap'
---

<!doctype html>
<html lang="es-BO" class="scroll-smooth scroll-pt-24">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <script is:inline>
      (() => {
        let theme
        try { theme = localStorage.getItem('theme') } catch {}
        const dark = theme ? theme === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches
        document.documentElement.classList.toggle('dark', dark)
        document.documentElement.style.colorScheme = dark ? 'dark' : 'light'
      })()
    </script>

    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f8fafc" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#09090b" />
    <meta name="application-name" content="DEVSJEC SRL" />
    <meta name="format-detection" content="telephone=no" />

    <SEO {...seoProps} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

    <link rel="preload" as="style" href={fontCssHref} onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href={fontCssHref} /></noscript>

    <link rel="preload" as="style" href={iconsCssHref} onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href={iconsCssHref} /></noscript>

    {import.meta.env.PROD && PUBLIC_ENVIRONMENTS.UMAMI_SRC && PUBLIC_ENVIRONMENTS.UMAMI_WEBSITE_ID && (
      <script is:inline defer src={PUBLIC_ENVIRONMENTS.UMAMI_SRC} data-website-id={PUBLIC_ENVIRONMENTS.UMAMI_WEBSITE_ID}></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
